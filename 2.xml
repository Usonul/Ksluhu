    <script src="Build/Barri.loader.js"></script>
    <script>
        const barraPreenchimento = document.querySelector("#loading-bar-fill");
        const telaCarregamento = document.querySelector("#loading-container");
        const canvasUnity = document.querySelector("#unity-canvas");

        // Função genérica auxiliar para baixar e remontar arquivos em paralelo
        async function baixarEUnificarArquivos(urls, tipoConteudo) {
            const promessas = urls.map(url => fetch(url).then(resposta => {
                if (!resposta.ok) {
                    throw new Error(`Falha ao baixar fragmento: ${url}`);
                }
                return resposta.arrayBuffer();
            }));

            const buffers = await Promise.all(promessas);
            const blobCompleto = new Blob(buffers, { type: tipoConteudo });
            return URL.createObjectURL(blobCompleto);
        }

        async function iniciarJogoUnity() {
            // Links exatos fornecidos para as partes do WebAssembly
            const urlsWasm = [
                "https://cdn.jsdelivr.net/gh/Usonul/Fg@8bc35ca/Barri.wasm.00.part",
                "https://cdn.jsdelivr.net/gh/Usonul/Huluks@90b9a21/Barri.wasm.01.part",
                "https://cdn.jsdelivr.net/gh/Usonul/kshuli@bc8a6f8/Barri.wasm.02.part",
                "https://cdn.jsdelivr.net/gh/Usonul/kshuli@bc8a6f8/Barri.wasm.03.part",
                "https://cdn.jsdelivr.net/gh/Usonul/kshuli@bc8a6f8/Barri.wasm.04.part"
            ];

            // Links exatos fornecidos para as partes do arquivo de dados (.data)
            const urlsData = [
                "https://cdn.jsdelivr.net/gh/Usonul/Ksluhu@a96a0fe/Build/Barri.data.00.part",
                "https://cdn.jsdelivr.net/gh/Usonul/Ksluhu@a96a0fe/Build/Barri.data.01.part",
                "https://cdn.jsdelivr.net/gh/Usonul/Ksluhu@a96a0fe/Build/Barri.data.02.part"
            ];

            try {
                // Baixa o WASM e o DATA juntos em segundo plano
                const [wasmBlobUrl, dataBlobUrl] = await Promise.all([
                    baixarEUnificarArquivos(urlsWasm, "application/wasm"),
                    baixarEUnificarArquivos(urlsData, "application/octet-stream")
                ]);

                // Inicializa a instância da Unity com os arquivos decodificados na memória
                createUnityInstance(canvasUnity, {
                    dataUrl: dataBlobUrl,
                    frameworkUrl: "Build/Barri.framework.js",
                    codeUrl: wasmBlobUrl 
                }, (progress) => {
                    barraPreenchimento.style.width = (100 * progress) + "%";
                }).then((instance) => {
                    window.unityInstance = instance;
                    telaCarregamento.style.display = 'none';
                    canvasUnity.style.display = 'block';
                }).catch((err) => {
                    alert("Erro ao inicializar motor da Unity: " + err);
                });

            } catch (err) {
                alert("Erro ao processar downloads dos repositórios: " + err.message);
            }
        }

        // Dá a largada no carregamento
        iniciarJogoUnity();
    </script>

<div id="tampa-botao-dinamica" style="position: fixed; background: transparent; z-index: 99998; pointer-events: auto;"></div>
<script>
function travarTampa() {
    const canvas = document.querySelector('canvas') || document.getElementById('unity-canvas');
    const tampa = document.getElementById('heatmap-botao-dinamica') || document.getElementById('tampa-botao-dinamica');
    if (!canvas || !tampa) return;

    const r = canvas.getBoundingClientRect();

    tampa.style.left = (r.left + (r.width * 0.0492)) + 'px';
    tampa.style.top = (r.top + (r.height * 0.0247)) + 'px';
    tampa.style.width = (r.width * 0.1055) + 'px';
    tampa.style.height = (r.height * 0.0753) + 'px';
}
window.addEventListener('resize', travarTampa);
window.addEventListener('load', () => setTimeout(travarTampa, 1000));
setInterval(travarTampa, 200);
</script>

<div id="overlay">
